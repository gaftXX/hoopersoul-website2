              — {{ form.errors.messages.email }}
            {%- endif -%}
          </div>
        {%- endif -%}

        <div
          id="vampire-contact-fields-{{ section.id }}"
          {% if form.posted_successfully? %}
            hidden
          {% endif %}
        >
          <div class="vampire-landing-{{ section.id }}__contact-field">
            <label class="visually-hidden" for="VampireContact-name-{{ section.id }}">
              {{- 'templates.contact.form.name' | t -}}
            </label>
            <input
              type="text"
              class="vampire-landing-{{ section.id }}__contact-input"
              id="VampireContact-name-{{ section.id }}"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              autocomplete="name"
              placeholder="{{ 'templates.contact.form.name' | t }}*"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              required
            >
          </div>

          <div class="vampire-landing-{{ section.id }}__contact-field">
            <label class="visually-hidden" for="VampireContact-email-{{ section.id }}">
              {{- 'templates.contact.form.email' | t -}}
            </label>
            <input
              type="email"
              class="vampire-landing-{{ section.id }}__contact-input"
              id="VampireContact-email-{{ section.id }}"
              name="contact[email]"
              autocomplete="email"
              autocapitalize="off"
              spellcheck="false"
              placeholder="{{ 'templates.contact.form.email' | t }}*"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
              {% endif %}
              required
            >
          </div>

          <div class="vampire-landing-{{ section.id }}__contact-field">
            <label class="visually-hidden" for="VampireContact-body-{{ section.id }}">
              {{- 'templates.contact.form.comment' | t -}}
            </label>
            <textarea
              class="vampire-landing-{{ section.id }}__contact-textarea"
              id="VampireContact-body-{{ section.id }}"
              name="contact[{{ 'templates.contact.form.comment' | t }}]"
              placeholder="{{ 'templates.contact.form.comment' | t }}*"
              rows="5"
              required
            >
              {{- form.body -}}
            </textarea>
          </div>

          <div class="vampire-landing-{{ section.id }}__contact-legal">
            <label class="vampire-landing-{{ section.id }}__contact-legal-label">
              <input
                class="vampire-landing-{{ section.id }}__contact-checkbox"
                type="checkbox"
                name="contact[Legal terms accepted]"
                value="yes"
                required
              >
              <span class="vampire-landing-{{ section.id }}__contact-legal-copy">
                <span class="vampire-landing-{{ section.id }}__contact-legal-preface">I accept</span>
                {%- if vampire_terms_url != blank -%}
                  <a
                    href="{{ vampire_terms_url }}"
                    class="vampire-landing-{{ section.id }}__contact-legal-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    >legal terms</a
                  >
                {%- else -%}
                  <span class="vampire-landing-{{ section.id }}__contact-legal-link">legal terms</span>
                {%- endif -%}
              </span>
            </label>
          </div>

          <button type="submit" class="vampire-landing-{{ section.id }}__contact-send">send</button>
        </div>
      {%- endform -%}
    </aside>
    <button
      type="button"
      class="vampire-landing-{{ section.id }}__contact-scrim"
      aria-label="{{ 'accessibility.close' | t }}"
      data-vampire-close-contact
    ></button>
  </div>
</section>

<script>
  (function () {
    const sectionId = '{{ section.id }}';
    const sectionEl = document.getElementById('shopify-section-' + sectionId);

    const countdownEl = document.getElementById('vampire-countdown-' + sectionId);
    if (countdownEl) {
      // 22 May 2026, 10:00 AM Barcelona time (CEST, UTC+2)
      const targetTime = Date.UTC(2026, 4, 22, 8, 0, 0);

      const updateCountdown = () => {
        const now = Date.now();
        const diff = targetTime - now;

        if (diff <= 0) {
          countdownEl.textContent = 'LIVE NOW';
          return;
        }

        const totalSeconds = Math.floor(diff / 1000);
        const hoursRemaining = Math.floor(totalSeconds / 3600);
        const minutesRemaining = Math.floor((totalSeconds % 3600) / 60);
        const secondsRemaining = totalSeconds % 60;
        countdownEl.textContent =
          hoursRemaining +
          'H ' +
          String(minutesRemaining).padStart(2, '0') +
          'M ' +
          String(secondsRemaining).padStart(2, '0') +
          'S';
      };

      updateCountdown();
      setInterval(updateCountdown, 1000);
    }

    if (sectionEl) {
      sectionEl.querySelectorAll('.vampire-landing-' + sectionId + '__video-bg video').forEach(function (v) {
        v.setAttribute('playsinline', '');
        v.muted = true;
        var playTry = v.play();
        if (playTry && playTry.catch) playTry.catch(function () {});
      });
    }

    if (!sectionEl) return;

    const root = document.getElementById('vampire-contact-dialog-' + sectionId);
    const trigger = document.getElementById('vampire-contact-trigger-' + sectionId);
    const closeNodes = sectionEl.querySelectorAll('[data-vampire-close-contact]');

    function openDrawer() {
      if (!root) return;
      root.classList.add('is-open');
      root.setAttribute('aria-hidden', 'false');
      if (trigger) trigger.setAttribute('aria-expanded', 'true');
      document.documentElement.style.overflow = 'hidden';
      var toFocus = root.querySelector('.vampire-landing-' + sectionId + '__contact-close');
      if (toFocus) toFocus.focus({ preventScroll: true });
    }

    function closeDrawer() {
      if (!root) return;
      root.classList.remove('is-open');
      root.setAttribute('aria-hidden', 'true');
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';
      if (trigger) trigger.focus({ preventScroll: true });
    }

    if (trigger && root) {
      trigger.addEventListener('click', function () {
        openDrawer();
      });
    }

    closeNodes.forEach(function (btn) {
      btn.addEventListener('click', function () {
        closeDrawer();
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && root && root.classList.contains('is-open')) {
        closeDrawer();
      }
    });

    var params = new URLSearchParams(window.location.search);
    if (params.get('contact_posted') === 'true') {
      var successEl = document.getElementById('vampire-contact-success-' + sectionId);
      var fieldsEl = document.getElementById('vampire-contact-fields-' + sectionId);
      if (successEl) successEl.hidden = false;
      if (fieldsEl) fieldsEl.hidden = true;
      openDrawer();
      if (successEl) successEl.focus({ preventScroll: true });
    }

    var okBanner = document.getElementById('vampire-contact-success-' + sectionId);
    var fieldWrap = document.getElementById('vampire-contact-fields-' + sectionId);
    if (okBanner && fieldWrap && !okBanner.hidden && fieldWrap.hidden) {
      openDrawer();
      okBanner.focus({ preventScroll: true });
    }
  })();
</script>

