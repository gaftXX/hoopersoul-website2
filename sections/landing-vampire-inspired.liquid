  </p>

  <p class="vampire-landing-{{ section.id }}__bottom-label vampire-landing-{{ section.id }}__bottom-label--left">
    {{ section.settings.left_bottom_label }}
  </p>
  <p class="vampire-landing-{{ section.id }}__bottom-label vampire-landing-{{ section.id }}__bottom-label--right">
    {{ section.settings.right_bottom_label }}
  </p>

  <p class="vampire-landing-{{ section.id }}__corner-copy vampire-landing-{{ section.id }}__corner-copy--left">
    {{ section.settings.small_copy }}
  </p>
  <p class="vampire-landing-{{ section.id }}__corner-copy vampire-landing-{{ section.id }}__corner-copy--right">
    {{ section.settings.small_copy }}
  </p>

  <div
    id="vampire-contact-dialog-{{ section.id }}"
    class="vampire-landing-{{ section.id }}__contact-root"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="vampire-contact-title-{{ section.id }}"
  >
    <aside class="vampire-landing-{{ section.id }}__contact-panel">
      <button
        type="button"
        class="vampire-landing-{{ section.id }}__contact-close"
        data-vampire-close-contact
      >
        [CLOSE]
      </button>
      <h2 class="vampire-landing-{{ section.id }}__contact-title" id="vampire-contact-title-{{ section.id }}">contact</h2>

      {%- form 'contact', id: vampire_form_id, class: vampire_form_class -%}
