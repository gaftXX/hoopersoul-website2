  {%- liquid
    assign cta_words = section.settings.top_right_label | split: ' '
    assign cta_first = cta_words | first
    assign vampire_form_id = 'ContactForm-vampire-' | append: section.id
    assign vampire_form_class = 'vampire-landing-' | append: section.id | append: '__contact-form-inner'
    assign vampire_terms_url = shop.terms_of_service.url
    if vampire_terms_url == blank and section.settings.legal_terms_url != blank
      assign vampire_terms_url = section.settings.legal_terms_url
    endif
  -%}
  <p class="vampire-landing-{{ section.id }}__cta">
    <button
      type="button"
      class="vampire-landing-{{ section.id }}__cta-contact"
      id="vampire-contact-trigger-{{ section.id }}"
      aria-expanded="false"
      aria-controls="vampire-contact-dialog-{{ section.id }}"
    >
      {{- cta_first | default: 'contact' -}}
    </button>
    {%- if cta_words.size > 1 -%}
      <span class="vampire-landing-{{ section.id }}__cta-rest">
        {%- for w in cta_words offset: 1 -%}
          {{- w -}}{%- unless forloop.last %} {% endunless -%}
        {%- endfor -%}
      </span>
    {%- endif -%}
