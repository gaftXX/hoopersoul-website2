          id="vampire-contact-success-{{ section.id }}"
          class="vampire-landing-{{ section.id }}__contact-status"
          {% unless form.posted_successfully? %}
            hidden
          {% endunless %}
          tabindex="-1"
        >
          {{ 'templates.contact.form.post_success' | t }}
        </div>

        {%- if form.errors -%}
          <div class="vampire-landing-{{ section.id }}__contact-status" role="alert" tabindex="-1">
            {{ 'templates.contact.form.error_heading' | t }}
