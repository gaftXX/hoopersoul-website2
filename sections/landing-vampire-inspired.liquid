{%- style -%}
  #shopify-section-{{ section.id }} {
    margin: 0;
  }

  .vampire-landing-{{ section.id }} {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: #000;
    color: #fff;
    font-family: var(--font-heading-family);
    isolation: isolate;
  }

  .vampire-landing-{{ section.id }}__video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .vampire-landing-{{ section.id }}__video-bg-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .vampire-landing-{{ section.id }}__video-bg-media video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .vampire-landing-{{ section.id }}__video-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #000;
    pointer-events: none;
  }

  .vampire-landing-{{ section.id }}__small-copy {
    position: absolute;
    top: 0;
    width: min(34rem, 42vw);
    font-size: clamp(0.68rem, 0.9vw, 0.95rem);
    line-height: 1.15;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    opacity: 0.96;
    z-index: 3;
  }

  .vampire-landing-{{ section.id }}__small-copy--left {
    left: clamp(5px, 0.9vw, 10px);
    text-align: left;
  }

  .vampire-landing-{{ section.id }}__small-copy--right {
    right: clamp(5px, 0.9vw, 10px);
    text-align: right;
  }

  .vampire-landing-{{ section.id }}__wordmark {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    width: max-content;
    filter: none;
    opacity: 1;
    z-index: 2;
    color: #fff;
  }

  .vampire-landing-{{ section.id }}__wordmark-logos {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 44px);
  }

  .vampire-landing-{{ section.id }}__wordmark-logo-wrap {
    position: relative;
    width: clamp(72px, 6.8vw, 130px);
  }

  .vampire-landing-{{ section.id }}__wordmark-logo {
    display: block;
    width: 100%;
    height: auto;
    filter: blur(5.5px);
    transition: filter 220ms ease;
    transition-delay: 140ms;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .vampire-landing-{{ section.id }}__wordmark-logo--base {
    opacity: 1;
    transition: opacity 140ms ease, filter 220ms ease;
    transition-delay: 0ms, 140ms;
  }

  .vampire-landing-{{ section.id }}__wordmark-logo--color {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 260ms ease;
    transition-delay: 0ms;
    pointer-events: none;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo {
    filter: none;
    transition-delay: 0ms;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo--base,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo--base {
    opacity: 0;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo-wrap--1 .vampire-landing-{{ section.id }}__wordmark-logo--base,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo-wrap--1 .vampire-landing-{{ section.id }}__wordmark-logo--base {
    transition-delay: 160ms, 0ms;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo-wrap--1 .vampire-landing-{{ section.id }}__wordmark-logo--color,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo-wrap--1 .vampire-landing-{{ section.id }}__wordmark-logo--color {
    transition-delay: 160ms;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo-wrap--2 .vampire-landing-{{ section.id }}__wordmark-logo--color,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo-wrap--2 .vampire-landing-{{ section.id }}__wordmark-logo--color {
    transition-delay: 230ms;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo-wrap--2 .vampire-landing-{{ section.id }}__wordmark-logo--base,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo-wrap--2 .vampire-landing-{{ section.id }}__wordmark-logo--base {
    transition-delay: 230ms, 0ms;
  }

  .vampire-landing-{{ section.id }}__wordmark-mark {
    position: absolute;
    left: 100%;
    top: 4px;
    margin-left: 2px;
    font-size: clamp(11px, 1.1vw, 18px);
    font-weight: 300;
    line-height: 1;
    color: #fff;
    filter: none;
    user-select: none;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo-wrap--3 .vampire-landing-{{ section.id }}__wordmark-logo--color,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo-wrap--3 .vampire-landing-{{ section.id }}__wordmark-logo--color {
    transition-delay: 300ms;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo-wrap--3 .vampire-landing-{{ section.id }}__wordmark-logo--base,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo-wrap--3 .vampire-landing-{{ section.id }}__wordmark-logo--base {
    transition-delay: 300ms, 0ms;
  }

  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-mark {
    filter: none;
  }

  .vampire-landing-{{ section.id }}__wordmark:hover .vampire-landing-{{ section.id }}__wordmark-logo--color,
  .vampire-landing-{{ section.id }}__wordmark:focus-within .vampire-landing-{{ section.id }}__wordmark-logo--color {
    opacity: 1;
  }

  .vampire-landing-{{ section.id }}__cta {
    position: absolute;
    right: clamp(5px, 0.9vw, 12px);
    top: clamp(28px, 3.8vw, 50px);
    margin: 0;
    font-size: clamp(1.2rem, 2.7vw, 3.2rem);
    line-height: 0.9;
    text-transform: lowercase;
    z-index: 3;
  }

  .vampire-landing-{{ section.id }}__center-copy {
    position: absolute;
    left: 50%;
    bottom: clamp(10px, 1.6vw, 20px);
    transform: translateX(-50%);
    margin: 0;
    width: min(92%, 1200px);
    font-size: clamp(3.2rem, 8.4vw, 8.8rem);
    line-height: 0.84;
    text-transform: uppercase;
    text-align: center;
    z-index: 3;
    letter-spacing: 0.01em;
  }

  .vampire-landing-{{ section.id }}__center-main {
    display: block;
    font-size: 1.16em;
    line-height: 0.82;
  }

  .vampire-landing-{{ section.id }}__tel {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: 0.4em;
    font-family: inherit;
    text-transform: none;
    font-style: normal;
    font-weight: inherit;
    font-size: 0.46em;
    letter-spacing: -0.01em;
    margin-bottom: 0.04em;
  }

  .vampire-landing-{{ section.id }}__tel-meta {
    opacity: 0.55;
    font-size: 1em;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .vampire-landing-{{ section.id }}__tel-link {
    color: inherit;
    text-decoration: none;
  }

  .vampire-landing-{{ section.id }}__tel-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.08em;
  }

  .vampire-landing-{{ section.id }}__bottom-label {
    position: absolute;
    bottom: clamp(34px, 4.5vw, 64px);
    margin: 0;
    font-size: clamp(2.1rem, 5.7vw, 6.4rem);
    line-height: 0.9;
    text-transform: uppercase;
    z-index: 3;
  }

  .vampire-landing-{{ section.id }}__bottom-label--left {
    left: clamp(5px, 0.9vw, 10px);
  }

  .vampire-landing-{{ section.id }}__bottom-label--right {
    right: clamp(5px, 0.9vw, 10px);
  }

  .vampire-landing-{{ section.id }}__corner-copy {
    position: absolute;
    bottom: clamp(3px, 0.6vw, 8px);
    width: min(26rem, 34vw);
    margin: 0;
    font-size: clamp(0.66rem, 0.86vw, 0.92rem);
    line-height: 1.12;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    z-index: 3;
    opacity: 0.95;
  }

  .vampire-landing-{{ section.id }}__corner-copy--left {
    left: clamp(5px, 0.9vw, 10px);
    text-align: left;
  }

  .vampire-landing-{{ section.id }}__corner-copy--right {
    right: clamp(5px, 0.9vw, 10px);
    text-align: right;
  }

  @media screen and (max-width: 989px) {
    .vampire-landing-{{ section.id }} {
      min-height: 100svh;
    }

    .vampire-landing-{{ section.id }}__small-copy,
    .vampire-landing-{{ section.id }}__corner-copy {
      width: min(17rem, 47vw);
    }

    .vampire-landing-{{ section.id }}__center-copy {
      width: min(96%, 820px);
      bottom: clamp(10px, 1.6vw, 20px);
      font-size: clamp(2.7rem, 9.6vw, 6rem);
    }

    .vampire-landing-{{ section.id }}__contact-title {
      font-size: calc(1.16 * clamp(2.7rem, 9.6vw, 6rem));
    }
  }

  @media screen and (max-width: 749px) {
    .vampire-landing-{{ section.id }}__small-copy,
    .vampire-landing-{{ section.id }}__corner-copy {
      display: none;
    }

    .vampire-landing-{{ section.id }}__wordmark {
      top: 48px;
    }

    .vampire-landing-{{ section.id }}__wordmark-logos {
      gap: 18px;
    }

    .vampire-landing-{{ section.id }}__wordmark-logo-wrap {
      width: clamp(54px, 22vw, 96px);
    }

    .vampire-landing-{{ section.id }}__wordmark-mark {
      font-size: clamp(9px, 3.8vw, 14px);
      top: 2px;
      margin-left: 2px;
    }

    .vampire-landing-{{ section.id }}__cta {
      top: 120px;
      right: 16px;
      font-size: clamp(1.25rem, 7vw, 2.3rem);
    }

    .vampire-landing-{{ section.id }}__center-copy {
      width: calc(100% - 24px);
      bottom: 20px;
      font-size: clamp(2.3rem, 10.2vw, 4.4rem);
    }

    .vampire-landing-{{ section.id }}__bottom-label {
      bottom: 32px;
      font-size: clamp(2.2rem, 12vw, 3.6rem);
    }
  }

  .vampire-landing-{{ section.id }}__cta-contact {
    margin: 0;
    padding: 0;
    border: none;
    background: none;
    font: inherit;
    color: inherit;
    text-transform: inherit;
    line-height: inherit;
    cursor: pointer;
    text-decoration: none;
  }

  .vampire-landing-{{ section.id }}__cta-contact:hover {
    text-decoration: none;
  }

  .vampire-landing-{{ section.id }}__cta-contact:focus-visible {
    text-decoration: none;
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .vampire-landing-{{ section.id }}__cta-rest {
    margin-inline-start: 0.35em;
  }

  .vampire-landing-{{ section.id }}__contact-root {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 0;
    height: 100vh;
    height: 100dvh;
    pointer-events: none;
    visibility: hidden;
  }

  .vampire-landing-{{ section.id }}__contact-root.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .vampire-landing-{{ section.id }}__contact-panel {
    grid-column: 1;
    grid-row: 1;
    background: #fccb00;
    color: #000;
    overflow: auto;
    padding: clamp(10px, 1.2vw, 18px) clamp(10px, 1.4vw, 22px) clamp(20px, 2.5vw, 36px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    box-sizing: border-box;
  }

  .vampire-landing-{{ section.id }}__contact-close {
    margin: 0 0 clamp(4px, 0.55vw, 9px);
    padding: 0;
    border: none;
    background: none;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: clamp(1.35rem, 3.6vw, 2rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    color: #000;
    cursor: pointer;
    text-transform: uppercase;
    text-decoration: none;
  }

  .vampire-landing-{{ section.id }}__contact-close:hover {
    text-decoration: none;
  }

  .vampire-landing-{{ section.id }}__contact-close:focus-visible {
    text-decoration: none;
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .vampire-landing-{{ section.id }}__contact-title {
    margin: -0.08em 0 clamp(14px, 2.2vw, 28px);
    padding: 0;
    font-family: 'Proxima Nova', var(--font-heading-family), Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
    font-weight: 900;
    font-size: calc(1.16 * clamp(3.2rem, 8.4vw, 8.8rem));
    line-height: 0.88;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: #000;
  }

  .vampire-landing-{{ section.id }}__contact-form-inner {
    width: 100%;
    max-width: 100%;
  }

  .vampire-landing-{{ section.id }}__contact-field {
    --vl-contact-field-inset: clamp(5px, 0.85vw, 8px);
    position: relative;
    margin-bottom: clamp(14px, 2vw, 22px);
    border: 1px solid #000;
    background: #fccb00;
    box-sizing: border-box;
  }

  .vampire-landing-{{ section.id }}__contact-input,
  .vampire-landing-{{ section.id }}__contact-textarea {
    display: block;
    width: 100%;
    margin: 0;
    border: none;
    background: transparent;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: clamp(1.35rem, 3.6vw, 2rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: #000;
    box-sizing: border-box;
  }

  .vampire-landing-{{ section.id }}__contact-input {
    padding: var(--vl-contact-field-inset);
    height: calc(var(--vl-contact-field-inset) * 2 + 1.2em);
    overflow: hidden;
    -webkit-appearance: none;
    appearance: none;
    border-radius: 0;
    caret-color: #000;
  }

  .vampire-landing-{{ section.id }}__contact-textarea {
    padding: var(--vl-contact-field-inset);
    /* Five lines at line-height 1.2 → 6em text block */
    height: calc(var(--vl-contact-field-inset) * 2 + 6em);
    min-height: calc(var(--vl-contact-field-inset) * 2 + 6em);
    resize: vertical;
    -webkit-appearance: none;
    appearance: none;
    border-radius: 0;
    caret-color: #000;
    vertical-align: top;
  }

  .vampire-landing-{{ section.id }}__contact-input::placeholder,
  .vampire-landing-{{ section.id }}__contact-textarea::placeholder {
    font-family: inherit;
    font-size: inherit;
    font-weight: 300;
    font-style: normal;
    letter-spacing: inherit;
    line-height: 1.2;
    color: #000;
    opacity: 1;
  }

  .vampire-landing-{{ section.id }}__contact-input::-webkit-input-placeholder,
  .vampire-landing-{{ section.id }}__contact-textarea::-webkit-input-placeholder {
    font-family: inherit;
    font-size: inherit;
    font-weight: 300;
    line-height: 1.2;
    color: #000;
  }

  .vampire-landing-{{ section.id }}__contact-input::-moz-placeholder,
  .vampire-landing-{{ section.id }}__contact-textarea::-moz-placeholder {
    font-family: inherit;
    font-size: inherit;
    font-weight: 300;
    line-height: 1.2;
    color: #000;
    opacity: 1;
  }

  .vampire-landing-{{ section.id }}__contact-input:focus,
  .vampire-landing-{{ section.id }}__contact-input:focus-visible,
  .vampire-landing-{{ section.id }}__contact-textarea:focus,
  .vampire-landing-{{ section.id }}__contact-textarea:focus-visible {
    outline: none;
    box-shadow: none;
  }

  .vampire-landing-{{ section.id }}__contact-legal {
    margin: clamp(4px, 0.8vw, 10px) 0 clamp(12px, 1.6vw, 20px);
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: clamp(1.35rem, 3.6vw, 2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.35;
  }

  .vampire-landing-{{ section.id }}__contact-legal-label {
    display: flex;
    align-items: center;
    gap: 0.55em;
    cursor: pointer;
    color: #000;
  }

  .vampire-landing-{{ section.id }}__contact-legal-copy {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 0.45em;
    row-gap: 0.2em;
    line-height: 1.35;
  }

  .vampire-landing-{{ section.id }}__contact-legal-preface {
    white-space: nowrap;
  }

  .vampire-landing-{{ section.id }}__contact-checkbox {
    flex-shrink: 0;
    width: 1.45em;
    height: 1.45em;
    min-width: 1.45em;
    min-height: 1.45em;
    aspect-ratio: 1;
    margin: 0;
    cursor: pointer;
    align-self: center;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    border: 1px solid #000;
    border-radius: 50%;
    background: #fccb00;
    box-sizing: border-box;
  }

  .vampire-landing-{{ section.id }}__contact-checkbox:checked {
    background: #000;
    border-color: #000;
  }

  .vampire-landing-{{ section.id }}__contact-checkbox:focus-visible {
    outline: 1px solid #000;
    outline-offset: 3px;
  }

  .vampire-landing-{{ section.id }}__contact-legal-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .vampire-landing-{{ section.id }}__contact-send {
    margin: clamp(-14px, -1.4vw, -6px) 0 0;
    padding: 0;
    border: none;
    background: none;
    font-family: 'Proxima Nova', var(--font-heading-family), Impact, Haettenschweiler, sans-serif;
    font-weight: 900;
    font-size: clamp(2.85rem, 7vw, 5rem);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #000;
    cursor: pointer;
    line-height: 1;
  }

  .vampire-landing-{{ section.id }}__contact-send:hover,
  .vampire-landing-{{ section.id }}__contact-send:focus-visible {
    text-decoration: none;
  }

  .vampire-landing-{{ section.id }}__contact-scrim {
    grid-column: 2;
    grid-row: 1;
    min-height: 0;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    background: transparent;
  }

  .vampire-landing-{{ section.id }}__contact-status {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: clamp(0.75rem, 1.05vw, 0.9rem);
    line-height: 1.45;
    margin: 0 0 1rem;
  }

  @media screen and (max-width: 749px) {
    .vampire-landing-{{ section.id }}__contact-title {
      font-size: calc(1.16 * clamp(2.3rem, 10.2vw, 4.4rem));
    }

    .vampire-landing-{{ section.id }}__contact-send {
      font-size: clamp(2.35rem, 11vw, 3.75rem);
    }
  }
{%- endstyle -%}

<section class="vampire-landing-{{ section.id }}" aria-label="{{ section.settings.aria_label | escape }}">
  {%- liquid
    assign bg_shopify = section.settings.background_video
    assign bg_asset = section.settings.background_video_asset | strip
    assign bg_visible = false
    if bg_shopify != blank
      assign bg_visible = true
    elsif bg_asset != blank
      assign bg_visible = true
    endif
  -%}
  {%- if bg_visible -%}
    <div class="vampire-landing-{{ section.id }}__video-bg" aria-hidden="true">
      <div class="vampire-landing-{{ section.id }}__video-bg-media">
        {%- if bg_shopify != blank -%}
          {%- capture bg_video_markup -%}
            {{
              bg_shopify
              | video_tag:
                image_size: '3840x',
                autoplay: true,
                loop: section.settings.background_video_loop,
                muted: true,
                controls: false
            }}
          {%- endcapture -%}
          {{ bg_video_markup | replace_first: '<video', '<video playsinline=""' }}
        {%- elsif bg_asset != blank -%}
          {%- assign bg_ext = bg_asset | split: '.' | last | downcase -%}
          {%- liquid
            assign bg_mime = 'video/mp4'
            if bg_ext == 'webm'
              assign bg_mime = 'video/webm'
            elsif bg_ext == 'mov' or bg_ext == 'qt'
              assign bg_mime = 'video/quicktime'
            endif
          -%}
          <video
            class="vampire-landing-{{ section.id }}__video-bg-el"
            autoplay
            muted
            playsinline
            preload="metadata"
            {% if section.settings.background_video_loop %}loop{% endif %}
          >
            <source src="{{ bg_asset | asset_url }}" type="{{ bg_mime }}">
          </video>
        {%- endif -%}
      </div>
      {%- if section.settings.background_overlay_opacity > 0 -%}
        <div
          class="vampire-landing-{{ section.id }}__video-bg-overlay"
          style="opacity: {{ section.settings.background_overlay_opacity | divided_by: 100.0 }};"
